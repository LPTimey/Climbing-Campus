{
  "compilerOptions": {
    "target": "es2023",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "checkJs": true,
    "strict": true,
    "module": "esnext",
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "three": ["./node_modules/three/build/"],
      "three/addons": ["./node_modules/three/examples/jsm/"],
      "three/fonts": ["./node_modules/three/examples/fonts/"],
      "echarts": ["./node_modules/echarts/dist/"]
    },
    "types": ["node"]
  },
  "include": [
    "src",
    "get-timetable.mjs"
  ]
}